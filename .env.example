# 512AI Skills Engine - Environment Variables Reference
# This is an EXAMPLE file. Copy to .env and fill with real values.
# IMPORTANT: Never commit actual credentials to git.

# ============================================================================
# GitHub (Pattern Detection + Auto-Commits)
# ============================================================================
GITHUB_PAT=ghp_your_personal_access_token_here
# Scope: repo, workflow (for GitHub Actions)
# Get from: https://github.com/settings/tokens

# ============================================================================
# Slack (Notifications)
# ============================================================================
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# Get from: https://api.slack.com/apps → OAuth & Permissions

SLACK_SIGNING_SECRET=your-signing-secret-here
# Get from: https://api.slack.com/apps → Basic Information

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Get from: https://api.slack.com/apps → Incoming Webhooks

# ============================================================================
# Anthropic (Claude API)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# Get from: https://console.anthropic.com/account/keys

# ============================================================================
# Development / Testing
# ============================================================================
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug
